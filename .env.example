# Copy this file to .env.local and fill in your values.
# Only the "Core" block is required to run the app locally; every other
# block enables an optional feature and can be left blank.

# ── Core: Supabase ───────────────────────────────────────────────────────────
# From Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key -- server-side only, never expose to the browser.
# Used by cron, the AI briefing, and admin password resets.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the app (no trailing slash). Used for auth redirects
# and links in reminder emails. Locally this is http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Branding / locale ────────────────────────────────────────────────────────
# Display name of the manager the briefing and reminder emails are written for.
MANAGER_NAME=the manager
# IANA timezone the weekly briefing is written in and that week boundaries use.
APP_TIMEZONE=UTC

# Set to "true" only on a public demo deployment to show one-click "explore"
# logins on the sign-in screen. Leave unset for a real install.
NEXT_PUBLIC_DEMO_MODE=

# ── AI weekly briefing (optional) ────────────────────────────────────────────
# Uses the Vercel AI Gateway. Create a key in the Vercel dashboard.
AI_GATEWAY_API_KEY=your-ai-gateway-key

# ── Microsoft 365 calendar (optional) ────────────────────────────────────────
# Azure AD app registration with delegated Calendars.Read.Shared.
# Powers the "next 1:1" lookup and reminder timing.
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
# The shared mailbox whose calendar the 1:1s live on.
MANAGER_CALENDAR_EMAIL=manager@your-company.com

# ── Reminder emails (optional) ───────────────────────────────────────────────
# Resend API key + verified sender. The cron route sends nudge emails.
RESEND_API_KEY=your-resend-api-key
REMINDER_FROM_EMAIL=Strategic Tracker <noreply@your-company.com>
# Shared secret the GitHub Actions cron sends as a Bearer token.
CRON_SECRET=generate-a-long-random-string

# ── Smartsheet "Other Topics" feed (optional) ────────────────────────────────
# Pulls extra discussion items into the 1:1 view for a single direct report.
SMARTSHEET_API_TOKEN=your-smartsheet-token
SMARTSHEET_SHEET_ID=your-sheet-id
# Email (or substring) of the one DR this feed is shown for. Leave blank to disable.
NEXT_PUBLIC_SMARTSHEET_USER_EMAIL=
